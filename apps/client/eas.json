    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "ios": { "resourceClass": "m1-medium" },
      "android": { "buildType": "app-bundle" },
      "env": { "EXPO_PUBLIC_API_URL": "https://api.poolcare.africa/api" }
    }
  },
  "submit": {
    "production": {
      "ios": {},
      "android": {
